---
import BadgeEstado from '../atoms/BadgeEstado.astro';
import BotonPrimario from '../atoms/BotonPrimario.astro';
import CampoNombre from '../molecules/CampoNombre.astro';
import SelectorColor from '../molecules/SelectorColor.astro';
import TituloSeccion from '../atoms/TituloSeccion.astro';
import SubtituloTexto from '../atoms/SubtituloTexto.astro';
---

<section id="pantallaAcceso" class="mx-auto max-w-5xl px-4 py-10 md:py-14">
  <div class="mx-auto max-w-3xl rounded-[30px] border border-white/10 bg-[#0b1120] p-6 md:p-8">
    <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
      <div>
        <p class="text-[11px] uppercase tracking-[0.26em] text-slate-500">Espacio compartido</p>
        <div class="mt-2">
          <TituloSeccion texto="Constellation Cursors" />
        </div>
      </div>
      <BadgeEstado id="estadoConexion" texto="Conectando con el servidor" />
    </div>

    <div class="max-w-2xl">
      <SubtituloTexto texto="Presencia visual en directo. Personaliza tu estrella y entra en el espacio compartido." />
    </div>

    <div class="mt-8 grid gap-5">
      <CampoNombre />
      <SelectorColor />

      <div class="rounded-[24px] border border-white/10 bg-slate-950/70 p-5">
        <p class="text-[11px] uppercase tracking-[0.2em] text-slate-500">Vista previa</p>
        <div class="mt-4 flex items-center gap-4">
          <div id="vistaPreviaEstrella" class="relative flex h-16 w-16 items-center justify-center rounded-full">
            <div class="absolute h-12 w-12 rounded-full opacity-20 blur-xl" style="background:#38bdf8;"></div>
            <div class="relative h-4 w-4 rounded-full border border-white/70 bg-sky-400 shadow-[0_0_20px_rgba(255,255,255,0.18)]"></div>
          </div>
          <div>
            <p id="vistaPreviaNombre" class="text-base font-semibold text-white">Invitado</p>
            <p id="vistaPreviaColor" class="mt-1 text-sm text-slate-400">#38bdf8</p>
          </div>
        </div>
      </div>

      <div class="pt-1">
        <BotonPrimario id="botonEntrar" texto="Entrar" />
      </div>
    </div>
  </div>
</section>
