---
import BotonSecundario from '../atoms/BotonSecundario.astro';
---

<div class="border-b border-white/10 px-5 py-4 md:px-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <p class="text-xs uppercase tracking-[0.25em] text-slate-500">Espacio compartido</p>
      <h2 class="mt-1 text-xl font-semibold text-white md:text-2xl">Presencia visual en directo</h2>
    </div>

    <div class="flex flex-wrap items-center gap-3">
      <div class="rounded-full border border-white/10 bg-slate-950 px-4 py-2 text-xs text-slate-300">
        <span class="text-slate-500">Usuarios conectados:</span>
        <span id="contadorUsuarios" class="ml-2 font-semibold text-white">0</span>
      </div>
      <BotonSecundario id="botonVolver" texto="Cambiar usuario" />
    </div>
  </div>
</div>
