---
interface Props {
  id: string;
  name: string;
  placeholder?: string;
  value?: string;
  maxlength?: number;
}

const { id, name, placeholder = '', value = '', maxlength = 20 } = Astro.props;
---

<input
  id={id}
  name={name}
  type="text"
  maxlength={maxlength}
  placeholder={placeholder}
  value={value}
  class="w-full rounded-2xl border border-white/10 bg-slate-950/80 px-4 py-3 text-sm text-white outline-none transition placeholder:text-slate-500 focus:border-cyan-300/70"
/>
