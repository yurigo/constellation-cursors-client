---
interface Props {
  id?: string;
  type?: 'button' | 'submit' | 'reset';
  texto: string;
}

const { id, type = 'button', texto } = Astro.props;
---

<button
  id={id}
  type={type}
  class="inline-flex items-center justify-center rounded-2xl border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-slate-100 transition duration-200 hover:border-white/20 hover:bg-white/10"
>
  {texto}
</button>
