---
interface Props {
  color: string;
  seleccionado?: boolean;
}

const { color, seleccionado = false } = Astro.props;
---

<span
  class:list={[
    'block h-6 w-6 rounded-full border transition duration-200',
    seleccionado ? 'scale-110 border-white/80 shadow-[0_0_24px_rgba(255,255,255,0.25)]' : 'border-white/15',
  ]}
  style={`background:${color};`}
></span>
