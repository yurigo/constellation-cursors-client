---
interface Props {
  id?: string;
  type?: 'button' | 'submit' | 'reset';
  texto: string;
}

const { id, type = 'button', texto } = Astro.props;
---

<button
  id={id}
  type={type}
  class="inline-flex items-center justify-center rounded-2xl border border-cyan-300/30 bg-cyan-400/10 px-5 py-3 text-sm font-semibold text-cyan-100 transition duration-200 hover:border-cyan-200/60 hover:bg-cyan-300/15"
>
  {texto}
</button>
