---
interface Props {
  id?: string;
  texto: string;
}

const { id, texto } = Astro.props;
---

<div
  id={id}
  class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-2 text-xs text-slate-200"
>
  <span class="h-2.5 w-2.5 rounded-full bg-emerald-400 shadow-[0_0_14px_rgba(74,222,128,0.8)]"></span>
  <span>{texto}</span>
</div>
