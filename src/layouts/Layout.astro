---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Constellation Cursors' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Experiencia de cursores compartidos en tiempo real con Astro, Node.js y Socket.IO."
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
